  "title": "Global Retail Ltd. - Multi-Plant Transportation Planning using SAP TM",
  "difficulty": "Intermediate",
  "duration": "5 Days",
  "industry": "Retail Distribution",
  "objective": "Design an SAP TM solution for a retail company operating multiple distribution centers, multiple carriers and different transportation priorities while minimizing transportation cost and improving delivery performance.",
  "learningObjectives": [
    "Analyze multi-plant transportation requirements",
    "Design SAP TM master data and organizational structure",
    "Plan consolidation-aware transportation flows",
    "Select carriers using cost and service criteria",
    "Design positive and negative transportation test scenarios",
    "Define transportation KPI dashboard recommendations"
  ],
