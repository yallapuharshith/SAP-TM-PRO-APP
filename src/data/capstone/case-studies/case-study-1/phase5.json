        ["Truck Capacity Exceeded", "Shipment split automatically"],
        ["Carrier Unavailable", "Backup carrier selected"],
        ["Warehouse Delay", "Transportation schedule updated"],
        ["Freight Invoice", "Charges calculated correctly"],
        ["Management Dashboard", "KPIs displayed correctly"]
      ]
