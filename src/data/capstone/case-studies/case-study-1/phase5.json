    {
      "id": "SEC21",
      "type": "callout",
      "calloutType": "best-practice",
      "title": "Senior Consultant Advice",
      "content": "Not every issue reported during UAT is a defect. Always determine whether the system is failing to meet the approved design (defect) or whether the business is requesting new functionality (change request)."
    },
    {
      "id": "SEC22",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Accenture UAT Scenario",
      "content": "A business user requests additional functionality during UAT. Would you implement it before Go-Live? A consultant should discuss scope management, impact analysis, change control procedures, project timelines and business priorities before making a recommendation."
    },
