      "rows": [
        ["System not following approved design", "Defect", "Configuration issue"],
        ["Business wants new functionality", "Change Request", "Scope enhancement"],
        ["Master data missing", "Defect", "Incorrect setup"],
        ["New business policy introduced", "Change Request", "Business decision"]
      ]
    },
