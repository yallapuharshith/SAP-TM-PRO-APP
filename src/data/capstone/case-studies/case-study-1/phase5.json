    {
      "id": "SEC9",
      "type": "heading",
      "title": "Business Change Request"
    },
    {
      "id": "SEC10",
      "type": "email",
      "from": "Transportation Manager",
      "subject": "New Requirement During UAT",
      "body": "Business users want planners to manually override the automatically selected carrier whenever VIP customers place urgent orders. This requirement was not discussed during Blueprint workshops."
    },
    {
      "id": "SEC11",
      "type": "decision-point",
      "title": "Consultant Decision",
      "question": "How should you handle this request?",
      "options": [
        { "id": "A", "text": "Implement immediately before Go-Live." },
        { "id": "B", "text": "Evaluate business value, perform impact analysis and process through formal Change Request (CR)." },
        { "id": "C", "text": "Reject the request without discussion." }
      ],
      "recommendedAnswer": "B",
      "explanation": "New requirements discovered during UAT should be handled through formal change management. Direct implementation may impact project timelines, testing and Go-Live stability."
    },
    {
      "id": "SEC12",
      "type": "heading",
      "title": "Unexpected Business Defect"
    },
    {
      "id": "SEC13",
      "type": "paragraph",
      "content": "Business users report that SAP TM selected the lowest-cost carrier instead of the preferred premium carrier for a high-value shipment. The system behaved according to configuration, but the business expected different behavior."
    },
    {
      "id": "SEC14",
      "type": "consultant-task",
      "title": "Your Investigation",
      "tasks": [
        "Review carrier selection profile.",
        "Compare configuration with Blueprint.",
        "Determine whether this is a defect or a change request.",
        "Estimate implementation impact.",
        "Present recommendation to Change Control Board."
      ]
    },
    {
      "id": "SEC15",
      "type": "table",
      "title": "Defect vs Change Request Analysis",
      "headers": [
        "Situation",
        "Classification",
        "Reason"
