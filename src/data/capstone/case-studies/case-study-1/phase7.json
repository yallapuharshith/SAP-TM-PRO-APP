      "id": "SEC11",
      "type": "decision-point",
      "title": "Immediate Response",
      "question": "What should the consultant do first?",
      "options": [
        { "id": "A", "text": "Start debugging configuration immediately." },
        { "id": "B", "text": "Assess business impact, initiate the P1 bridge call, verify integrations and restore business operations first." },
        { "id": "C", "text": "Wait for users to provide more screenshots." }
      ],
      "recommendedAnswer": "B",
      "explanation": "For P1 incidents, restoring business operations and coordinating stakeholders takes priority over detailed root cause analysis."
