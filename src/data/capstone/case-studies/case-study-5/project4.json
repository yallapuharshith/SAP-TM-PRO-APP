  "industry": "Discrete Manufacturing",
  "objective": "Design an SAP TM solution that optimizes transportation planning, warehouse loading schedules, carrier utilization and freight costs while handling production constraints and urgent customer orders.",
  "learningObjectives": [
    "Design integrated transportation and warehouse planning flows",
    "Prioritize urgent shipments using business rules",
    "Improve load consolidation and truck utilization",
    "Handle resource and bay constraints in planning",
    "Define KPI-based optimization outcomes",
    "Propose process improvements for operational resilience"
  ],
