  "title": "ABC Electronics Transportation Optimization using SAP TM",
  "difficulty": "ASE / Beginner Consultant",
  "duration": "5 Days",
  "industry": "Consumer Electronics",
  "objective": "Design a complete SAP Transportation Management solution for ABC Electronics by analyzing business requirements, identifying SAP TM objects, proposing a transportation process, validating business scenarios and documenting the complete solution.",
  "learningObjectives": [
    "Analyze transportation business requirements",
    "Identify SAP TM master data and documents",
    "Design end-to-end transportation process",
    "Recommend planning and carrier strategies",
    "Define KPI-driven reporting approach",
    "Prepare final solution documentation"
  ],
