      "calloutType": "example",
      "title": "Real Project Example",
      "content": "A pharmaceutical company migrated from Standalone SAP TM to Embedded TM after implementing SAP S/4HANA, reducing interface maintenance while improving planning performance."
    },
    {
      "id": "SEC18",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "Know the difference between Embedded TM and Standalone TM. This is one of the most frequently asked SAP TM implementation questions."
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Do not assume Embedded TM has fewer capabilities. In modern SAP S/4HANA releases, Embedded TM supports most transportation planning scenarios required by customers."
    },
