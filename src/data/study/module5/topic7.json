  "learningObjectives": [
    {
      "id": "LO1",
      "title": "Understand resource planning",
      "description": "Explain assignment of suitable transport assets to freight orders for execution."
    },
    {
      "id": "LO2",
      "title": "Understand capacity validation",
      "description": "Describe how weight, volume, availability and compliance constraints are checked."
    },
    {
      "id": "LO3",
      "title": "Differentiate capacity and resource planning",
