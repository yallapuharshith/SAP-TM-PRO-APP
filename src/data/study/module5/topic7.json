    {
      "id": "SEC12",
      "type": "heading",
      "title": "Business Scenario"
    },
    {
      "id": "SEC13",
      "type": "paragraph",
      "content": "A shipment weighing 15 tons requires transportation from Hyderabad to Chennai. SAP TM evaluates available trucks, rejects vehicles with insufficient capacity and assigns a 20-ton truck that is available during the required delivery window."
    },
    {
      "id": "SEC14",
      "type": "comparison",
      "title": "Capacity Planning vs Resource Planning",
