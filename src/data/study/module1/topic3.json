    {
      "id": "SEC18",
      "type": "callout",
      "calloutType": "example",
      "title": "Real Project Example",
      "content": "A global retail company migrated from SAP ECC to SAP S/4HANA and reduced financial closing time from 5 days to less than 1 day due to real-time processing and embedded analytics."
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "When asked 'Why S/4HANA?', explain the simplified data model, SAP HANA database, embedded analytics, SAP Fiori and improved business performance instead of only saying 'it's faster'."
    },
    {
      "id": "SEC20",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Do not say SAP HANA and SAP S/4HANA are the same. SAP HANA is the database platform, while SAP S/4HANA is the ERP application running on HANA."
    },
