  "sections": [
    {
      "id": "SEC1",
      "type": "heading",
      "title": "What is SAP S/4HANA?"
    },
    {
      "id": "SEC2",
      "type": "paragraph",
      "content": "SAP S/4HANA is SAP's next-generation Enterprise Resource Planning (ERP) suite built exclusively on the SAP HANA in-memory database. It enables organizations to run transactional and analytical workloads in real time while providing a simplified data model and modern user experience."
    },
    {
      "id": "SEC3",
      "type": "callout",
      "calloutType": "important",
      "title": "Key Point",
      "content": "S/4HANA is not just an upgrade of SAP ECC. It is a redesigned ERP suite optimized for the SAP HANA database."
    },
    {
      "id": "SEC4",
      "type": "heading",
      "title": "SAP S/4HANA Architecture"
    },
    {
      "id": "SEC5",
      "type": "paragraph",
      "content": "SAP S/4HANA follows a three-layer architecture consisting of the Presentation Layer, Application Layer and Database Layer. This architecture provides scalability, security and high performance."
    },
    {
      "id": "SEC6",
      "type": "process-flow",
      "title": "Three-Tier Architecture",
      "orientation": "vertical",
      "steps": [
        "Presentation Layer (SAP GUI / SAP Fiori)",
        "Application Layer (Business Logic)",
        "SAP HANA Database"
      ]
    },
    {
      "id": "SEC7",
      "type": "table",
      "title": "Architecture Layers",
      "headers": [
        "Layer",
        "Responsibility"
      ],
      "rows": [
        [
          "Presentation Layer",
          "User Interface using SAP GUI and SAP Fiori"
        ],
        [
          "Application Layer",
          "Business Logic, Processing, Authorization"
        ],
        [
          "Database Layer",
          "SAP HANA stores transactional and master data"
        ]
      ]
    },
