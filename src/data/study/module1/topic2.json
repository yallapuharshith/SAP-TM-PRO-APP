      ]
    },
    {
      "id": "SEC13",
      "type": "callout",
      "calloutType": "best-practice",
      "title": "Best Practice",
      "content": "Organizations should implement standard SAP processes wherever possible instead of heavily customizing the system."
    },
    {
      "id": "SEC14",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Many beginners think SAP is only used by large companies. Today, SAP provides solutions suitable for businesses of various sizes through cloud offerings."
    }
