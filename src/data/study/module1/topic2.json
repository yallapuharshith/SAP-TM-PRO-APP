  "sections": [
    {
      "id": "SEC1",
      "type": "heading",
      "title": "Evolution of Business Systems"
    },
    {
      "id": "SEC2",
      "type": "paragraph",
      "content": "Business software evolved from manual record keeping to modern intelligent ERP systems. As organizations grew, isolated applications could no longer support integrated business operations, leading to the development of Enterprise Resource Planning (ERP)."
    },
    {
      "id": "SEC3",
      "type": "table",
      "title": "Evolution of Enterprise Systems",
      "headers": [
        "Generation",
        "Description"
      ],
      "rows": [
        ["Manual Systems", "Paper-based records and ledgers"],
        ["Standalone Applications", "Separate software for each department"],
        ["MRP", "Material Requirements Planning"],
        ["MRP II", "Manufacturing Resource Planning"],
        ["ERP", "Enterprise-wide integrated business system"],
        ["SAP S/4HANA", "Next-generation intelligent ERP"]
      ]
    },
    {
      "id": "SEC4",
      "type": "heading",
      "title": "What is SAP?"
    },
    {
      "id": "SEC5",
      "type": "paragraph",
      "content": "SAP stands for Systems, Applications and Products in Data Processing. It is one of the world's leading providers of enterprise application software, helping organizations manage finance, logistics, procurement, manufacturing, sales and transportation through an integrated platform."
    },
    {
      "id": "SEC6",
      "type": "callout",
      "calloutType": "important",
      "title": "Interview Tip",
      "content": "ERP is a business concept. SAP is a company that provides ERP software."
    },
    {
      "id": "SEC7",
      "type": "heading",
      "title": "Why Companies Choose SAP"
    },
    {
      "id": "SEC8",
      "type": "bullet-list",
      "items": [
        "Integrated business processes",
        "Real-time reporting",
        "Scalable architecture",
        "Global compliance",
        "Industry best practices",
        "Cloud and On-Premise deployment",
        "Powerful analytics",
        "AI-enabled business processes"
      ]
    },
