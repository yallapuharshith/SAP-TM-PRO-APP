  "learningObjectives": [
    {
      "id": "LO1",
      "title": "Understand SAP module landscape",
      "description": "Identify major functional modules and their business purpose."
    },
    {
      "id": "LO2",
      "title": "Explain module integration",
      "description": "Describe how cross-module processes flow in SAP S/4HANA."
    },
    {
      "id": "LO3",
