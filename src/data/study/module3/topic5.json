      "id": "SEC12",
      "type": "heading",
      "title": "Business Scenario"
    },
    {
      "id": "SEC13",
      "type": "paragraph",
      "content": "A multinational electronics company ships products worldwide. Domestic shipments are automatically assigned to regional transportation planners, while export shipments are routed to a dedicated international planning organization using responsibility determination rules."
    },
    {
      "id": "SEC14",
      "type": "heading",
      "title": "Benefits of Responsibility Determination"
    },
    {
      "id": "SEC15",
      "type": "bullet-list",
      "items": [
        "Automatic planner assignment",
        "Balanced workload",
        "Reduced manual intervention",
        "Faster transportation planning",
        "Improved operational efficiency",
        "Consistent planning decisions"
      ]
    },
    {
      "id": "SEC16",
      "type": "comparison",
      "title": "Manual vs Automatic Responsibility Assignment",
      "leftTitle": "Manual Assignment",
      "rightTitle": "Automatic Assignment",
      "rows": [
        {
          "feature": "Assignment",
          "left": "Planner Chooses",
          "right": "Business Rules"
        },
        {
          "feature": "Speed",
          "left": "Slow",
          "right": "Immediate"
        },
        {
          "feature": "Consistency",
          "left": "Depends on User",
          "right": "Always Consistent"
        },
        {
          "feature": "Scalability",
          "left": "Limited",
          "right": "High"
        }
      ]
    },
    {
      "id": "SEC17",
      "type": "callout",
      "calloutType": "example",
      "title": "Real Project Example",
      "content": "A logistics provider operating across Europe configured planner determination using Transportation Zones. Every Freight Unit was automatically assigned to the correct regional planning team, reducing manual planner allocation by more than 90%."
    },
    {
      "id": "SEC18",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "Be prepared to explain how SAP TM automatically determines the responsible planner. Mention Planning Organizations, Planning Groups, Responsibility Determination Rules and Transportation Zones."
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Do not assume planner assignment is always manual. In most SAP TM implementations, planner determination is automated using predefined organizational rules."
    },
