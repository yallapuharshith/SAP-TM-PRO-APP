  "sections": [
    {
      "id": "SEC1",
      "type": "heading",
      "title": "Organizational Model Integration"
    },
    {
      "id": "SEC2",
      "type": "paragraph",
      "content": "The SAP TM Organizational Model is tightly integrated with master data, transportation planning and execution. It ensures that every transportation request is automatically assigned to the correct planning organization based on predefined business rules."
    },
    {
      "id": "SEC3",
      "type": "callout",
      "calloutType": "important",
      "title": "Key Concept",
      "content": "The Organizational Model is the backbone of planner assignment and responsibility determination in SAP TM."
    },
