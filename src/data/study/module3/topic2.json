    {
      "id": "SEC16",
      "type": "heading",
      "title": "Business Scenario"
    },
    {
      "id": "SEC17",
      "type": "paragraph",
      "content": "A transportation planner creates Freight Orders for today's deliveries. The dispatcher assigns trucks and drivers. The carrier executes transportation, while the warehouse loads goods. After delivery, the freight settlement specialist validates carrier invoices before payment."
    },
    {
      "id": "SEC18",
      "type": "comparison",
      "title": "Planner vs Dispatcher",
      "leftTitle": "Transportation Planner",
      "rightTitle": "Dispatcher",
      "rows": [
        {
          "feature": "Focus",
          "left": "Planning",
          "right": "Execution"
        },
        {
          "feature": "Main Activity",
          "left": "Freight Orders",
          "right": "Vehicle Assignment"
        },
        {
          "feature": "Optimization",
          "left": "Yes",
          "right": "Limited"
        }
      ]
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "example",
      "title": "Real Project Example",
      "content": "An automotive manufacturer has one central Planning Organization with 15 planners. Dispatchers assign over 250 trucks daily, while regional transportation managers monitor delivery KPIs using SAP TM dashboards."
    },
    {
      "id": "SEC20",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "Know the responsibilities of Transportation Planner, Dispatcher and Carrier. These roles are commonly discussed in SAP TM interviews and implementation workshops."
    },
    {
      "id": "SEC21",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Do not assume the Carrier performs transportation planning. Planning is done by the Transportation Planner; the Carrier executes the assigned transportation."
    },
