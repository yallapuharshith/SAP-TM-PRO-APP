  "learningObjectives": [
    {
      "id": "LO1",
      "title": "Understand exception management",
      "description": "Explain how SAP TM detects and manages execution deviations proactively."
    },
    {
      "id": "LO2",
      "title": "Understand exception workflow",
      "description": "Describe detection, alerting, planner review, and corrective action flow."
    },
    {
      "id": "LO3",
      "title": "Differentiate events and exceptions",
