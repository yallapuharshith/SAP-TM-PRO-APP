    {
      "id": "SEC12",
      "type": "heading",
      "title": "Business Scenario"
    },
    {
      "id": "SEC13",
      "type": "paragraph",
      "content": "A truck transporting medical equipment breaks down during transit. SAP TM immediately detects the delay through event management, creates an exception alert, notifies the transportation planner and recommends assigning another available truck to complete the delivery."
    },
    {
      "id": "SEC14",
      "type": "comparison",
      "title": "Event vs Exception",
      "leftTitle": "Transportation Event",
      "rightTitle": "Exception",
      "rows": [
        {
          "feature": "Purpose",
          "left": "Normal milestone",
          "right": "Unexpected issue"
        },
        {
          "feature": "Example",
          "left": "Shipment departed",
          "right": "Shipment delayed"
        },
        {
          "feature": "Planner Action",
          "left": "Usually none",
          "right": "Corrective action required"
        }
      ]
    },
    {
      "id": "SEC15",
      "type": "heading",
      "title": "Business Benefits"
    },
    {
      "id": "SEC16",
      "type": "bullet-list",
      "items": [
        "Early issue detection",
        "Reduced transportation disruptions",
        "Improved shipment visibility",
        "Better customer communication",
        "Faster problem resolution",
        "Improved service levels"
      ]
    },
    {
      "id": "SEC17",
      "type": "callout",
      "calloutType": "best-practice",
      "title": "Best Practice",
      "content": "Configure exception thresholds based on business priorities. Avoid generating excessive alerts that may overwhelm transportation planners."
    },
    {
      "id": "SEC18",
      "type": "callout",
      "calloutType": "example",
      "title": "Real Project Example",
      "content": "A pharmaceutical company configured automatic alerts whenever refrigerated shipments exceeded transit temperature limits. Planners received immediate notifications, reducing product spoilage and improving regulatory compliance."
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "Remember: Every exception originates from one or more transportation events, but not every transportation event becomes an exception."
    },
    {
      "id": "SEC20",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Do not treat every transportation event as an exception. Exceptions occur only when predefined business rules or execution expectations are violated."
    },
    {
      "id": "SEC21",
      "type": "heading",
      "title": "Revision Summary"
    },
    {
      "id": "SEC22",
      "type": "bullet-list",
      "items": [
        "Exception Management identifies transportation problems.",
        "Exceptions trigger alerts and corrective actions.",
        "Traffic delays, vehicle breakdowns and missed delivery windows are common exceptions.",
        "Event Management supplies the information used by Exception Management.",
        "Proactive exception handling improves customer service and operational efficiency."
      ]
    }
