  "sections": [
    {
      "id": "SEC1",
      "type": "heading",
      "title": "Exception Management"
    },
    {
      "id": "SEC2",
      "type": "paragraph",
      "content": "Exception Management enables SAP TM to identify, monitor and resolve unexpected transportation events that may affect shipment execution. Instead of reacting after problems occur, planners receive proactive alerts that allow corrective actions before customer service is impacted."
    },
    {
      "id": "SEC3",
      "type": "callout",
      "calloutType": "important",
      "title": "Key Concept",
      "content": "An exception is any transportation event that deviates from the planned execution process and requires attention."
    },
    {
      "id": "SEC4",
      "type": "heading",
      "title": "Objectives of Exception Management"
    },
    {
      "id": "SEC5",
      "type": "bullet-list",
      "items": [
        "Detect transportation issues early",
        "Notify planners automatically",
        "Reduce shipment delays",
        "Improve customer satisfaction",
        "Support corrective actions",
        "Minimize transportation risks",
        "Improve operational control"
      ]
    },
    {
