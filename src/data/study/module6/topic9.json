      "id": "SEC12",
      "type": "heading",
      "title": "Business Scenario"
    },
    {
      "id": "SEC13",
      "type": "paragraph",
      "content": "A logistics manager monitors 2,500 active Freight Orders using the SAP TM dashboard. One shipment changes to a delayed status due to heavy traffic. The dashboard immediately highlights the exception, allowing the planner to inform the customer and coordinate with the carrier."
    },
    {
      "id": "SEC14",
      "type": "comparison",
      "title": "Monitoring vs Reporting",
      "leftTitle": "Transportation Monitoring",
      "rightTitle": "Transportation Reporting",
      "rows": [
        {
          "feature": "Time",
          "left": "Real-Time",
          "right": "Historical"
        },
        {
          "feature": "Purpose",
          "left": "Operational Decisions",
          "right": "Performance Analysis"
        },
        {
