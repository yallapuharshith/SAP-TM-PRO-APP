  "sections": [
    {
      "id": "SEC1",
      "type": "heading",
      "title": "Transportation Monitoring & Execution Dashboard"
    },
    {
      "id": "SEC2",
      "type": "paragraph",
      "content": "Transportation Monitoring provides real-time visibility into transportation execution activities. SAP TM dashboards allow planners and logistics managers to monitor Freight Orders, shipment progress, transportation events, resource utilization, exceptions and KPIs from a centralized workspace."
    },
    {
      "id": "SEC3",
      "type": "callout",
      "calloutType": "important",
      "title": "Key Concept",
      "content": "Transportation Monitoring enables planners to proactively manage shipments instead of reacting after problems occur."
    },
    {
      "id": "SEC4",
      "type": "heading",
      "title": "Objectives of Transportation Monitoring"
    },
    {
      "id": "SEC5",
      "type": "bullet-list",
      "items": [
        "Monitor shipment execution",
        "Track Freight Orders",
        "View transportation events",
        "Identify exceptions",
        "Monitor resource utilization",
        "Support operational decision-making",
        "Improve customer visibility"
      ]
    },
