    {
      "id": "SEC15",
      "type": "heading",
      "title": "Business Benefits"
    },
    {
      "id": "SEC16",
      "type": "bullet-list",
      "items": [
        "Real-time shipment visibility",
        "Improved customer communication",
        "Early exception detection",
        "Better fleet utilization",
        "Improved carrier monitoring",
        "Faster operational decisions"
      ]
    },
    {
      "id": "SEC17",
      "type": "callout",
      "calloutType": "best-practice",
      "title": "Best Practice",
      "content": "Configure role-based dashboards so transportation planners, dispatchers and managers each see the KPIs and shipment information most relevant to their responsibilities."
    },
    {
      "id": "SEC18",
      "type": "callout",
      "calloutType": "example",
      "title": "Real Project Example",
      "content": "A third-party logistics provider implemented SAP TM dashboards integrated with GPS tracking. Dispatchers monitored over 8,000 shipments simultaneously and reduced average issue resolution time by nearly 45%."
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "Transportation Monitoring is operational and real-time, while reporting is analytical and historical. Certification exams frequently test this distinction."
    },
    {
      "id": "SEC20",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Monitoring dashboards display transportation information but do not replace transportation planning. Planning creates the shipment, monitoring tracks its execution."
    },
    {
