    {
      "id": "SEC12",
      "type": "heading",
      "title": "Business Scenario"
    },
    {
      "id": "SEC13",
      "type": "paragraph",
      "content": "A truck carrying electronics leaves the Hyderabad warehouse. SAP TM records loading completion, updates the departure event, tracks the vehicle using GPS integration, records proof of delivery at the customer site in Chennai and automatically updates the Freight Order status to Completed."
    },
    {
