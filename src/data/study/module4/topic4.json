  "sections": [
    {
      "id": "SEC1",
      "type": "heading",
      "title": "Transportation Zone in SAP TM"
    },
    {
      "id": "SEC2",
      "type": "paragraph",
      "content": "A Transportation Zone is a logical grouping of locations used for transportation planning, route determination and planner responsibility. Instead of maintaining transportation relationships for individual locations, SAP TM allows planners to group multiple locations into a single transportation zone."
    },
    {
      "id": "SEC3",
      "type": "callout",
      "calloutType": "important",
      "title": "Key Concept",
      "content": "Transportation Zones simplify transportation planning by grouping multiple locations into a single planning region."
    },
    {
      "id": "SEC4",
      "type": "heading",
      "title": "Why Transportation Zones are Required"
    },
    {
      "id": "SEC5",
      "type": "bullet-list",
      "items": [
        "Simplify transportation planning",
        "Reduce master data maintenance",
        "Support planner responsibility",
        "Enable transportation lane determination",
        "Improve route planning",
        "Support regional optimization"
      ]
    },
