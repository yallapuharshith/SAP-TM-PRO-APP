    {
      "id": "SEC17",
      "type": "callout",
      "calloutType": "example",
      "title": "Real Project Example",
      "content": "A logistics company grouped over 3,500 delivery locations into 45 Transportation Zones. This reduced Transportation Lane maintenance by nearly 80% while improving transportation planning performance."
    },
    {
      "id": "SEC18",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "Certification exams frequently ask why Transportation Zones are used instead of individual Locations. The correct answer is simplified planning, easier lane maintenance and automatic planner determination."
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "A Transportation Zone is not a physical location. It is a logical grouping of multiple locations used for planning and optimization."
    },
