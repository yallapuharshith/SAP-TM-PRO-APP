      "orientation": "horizontal",
      "steps": [
        "Source Location",
        "Transportation Lane",
        "Carrier",
        "Resource",
        "Destination Location",
        "Freight Order"
      ]
    },
    {
      "id": "SEC10",
      "type": "heading",
      "title": "Types of Transportation Lanes"
    },
    {
      "id": "SEC11",
      "type": "table",
      "title": "Lane Categories",
      "headers": [
        "Type",
        "Example"
      ],
      "rows": [
        [
          "Road",
          "Plant -> Customer"
        ],
