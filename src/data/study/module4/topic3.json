    },
    {
      "id": "SEC16",
      "type": "bullet-list",
      "items": [
        "Accurate route planning",
        "Distance calculation",
        "Optimized scheduling",
        "Improved shipment visibility",
        "Correct freight calculation",
        "Efficient transportation execution"
      ]
    },
    {
      "id": "SEC17",
      "type": "callout",
      "calloutType": "example",
      "title": "Real Project Example",
      "content": "An e-commerce company maintains over 2,500 warehouse and customer locations in SAP TM. GPS coordinates are used by the optimizer to calculate the shortest routes, reducing transportation distance and fuel costs."
    },
    {
      "id": "SEC18",
      "type": "callout",
      "calloutType": "interview-tip",
      "title": "Interview Tip",
      "content": "Expect questions like 'What is a Location in SAP TM?' and 'How is Location different from Business Partner?'. A Business Partner identifies a business entity, whereas a Location identifies the physical place where transportation activities occur."
    },
    {
      "id": "SEC19",
      "type": "callout",
      "calloutType": "warning",
      "title": "Common Mistake",
      "content": "Do not confuse Business Partner with Location. One Business Partner can have multiple Locations, such as headquarters, warehouses and delivery sites."
    },
